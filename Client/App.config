<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <connectionStrings>
        <!-- Đổi Data Source nếu máy bạn dùng LocalDB: (localdb)\MSSQLLocalDB -->
        <add name="QLSV" connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=QLSV_MRBEAST;Integrated Security=True;TrustServerCertificate=True" providerName="System.Data.SqlClient" />
    </connectionStrings>
    <appSettings>
        <add key="EncryptionKey" value="QLSV_TDMU_SecretKey_2026!" />
    </appSettings>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
</configuration>
